@prefix aem: <https://example.com/aem-assets-ontology#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

aem:AssetMetadata owl:Class ;
    rdfs:label "Asset Metadata Record" .

aem:sku aem:Property ;
    rdfs:label "SKU" ;
    aem:pattern "^[A-Z0-9-]+$" ;
    rdfs:comment "The unique product SKU associated with the asset." .

aem:brand aem:Property ;
    rdfs:label "Brand" ;
    aem:pattern "^[a-zA-Z\\s]+$" ;
    rdfs:comment "The brand associated with the asset." .

aem:pimCategory aem:Property ;
    rdfs:label "PIM Category" ;
    rdfs:comment "The category defined in the PIM system." .

aem:workfrontProjectId aem:Property ;
    rdfs:label "Workfront Project ID" ;
    aem:pattern "^[0-9a-f]{32}$" ;
    rdfs:comment "The 32-character hex ID from Adobe Workfront." .

aem:belongsToCampaign aem:Property ;
    rdfs:label "Campaign" ;
    rdfs:comment "The marketing campaign this asset belongs to." .

dc:title aem:Property ;
    rdfs:label "Title" .

dc:description aem:Property ;
    rdfs:label "Description" .

dc:format aem:Property ;
    rdfs:label "Mime Type" .
